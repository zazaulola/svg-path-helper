{
  "name": "svg-path-helper",
  "displayName": "SVG Path Studio",
  "description": "Live SVG preview with cursor-aware path highlighting and absolute/relative coordinate conversion.",
  "version": "0.3.2",
  "publisher": "zazaulola",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazaulola/svg-path-helper.git"
  },
  "homepage": "https://github.com/zazaulola/svg-path-helper#readme",
  "bugs": {
    "url": "https://github.com/zazaulola/svg-path-helper/issues"
  },
  "keywords": [
    "svg",
    "path",
    "preview",
    "bezier",
    "vector"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "svgPathHelper.svgPreview",
        "displayName": "SVG Path Studio Preview",
        "selector": [
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "svgPathHelper.showPreview",
        "title": "SVG Path: Open Preview",
        "category": "SVG Path",
        "icon": "$(open-preview)"
      },
      {
        "command": "svgPathHelper.toAbsolute",
        "title": "SVG Path: Convert selected path(s) to Absolute coordinates",
        "category": "SVG Path"
      },
      {
        "command": "svgPathHelper.toRelative",
        "title": "SVG Path: Convert selected path(s) to Relative coordinates",
        "category": "SVG Path"
      },
      {
        "command": "svgPathHelper.transformToMatrix",
        "title": "SVG Transform: Convert this transform to matrix()",
        "category": "SVG Transform"
      },
      {
        "command": "svgPathHelper.transformToMatrixDeep",
        "title": "SVG Transform: Convert this transform to matrix() (incl. nested)",
        "category": "SVG Transform"
      },
      {
        "command": "svgPathHelper.transformResolve",
        "title": "SVG Transform: Resolve (bake into geometry)",
        "category": "SVG Transform"
      },
      {
        "command": "svgPathHelper.transformResolveDeep",
        "title": "SVG Transform: Resolve (bake into geometry, incl. nested)",
        "category": "SVG Transform"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "svgPathHelper.showPreview",
          "when": "resourceExtname == .svg || editorLangId == svg || editorLangId == xml",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "svgPathHelper.toAbsolute",
          "when": "resourceExtname == .svg || editorLangId == svg || editorLangId == xml || editorLangId == html",
          "group": "svgPathHelper@1"
        },
        {
          "command": "svgPathHelper.toRelative",
          "when": "resourceExtname == .svg || editorLangId == svg || editorLangId == xml || editorLangId == html",
          "group": "svgPathHelper@2"
        },
        {
          "command": "svgPathHelper.transformToMatrix",
          "when": "svgPathHelper.cursorOnTransform",
          "group": "svgPathHelperTransform@1"
        },
        {
          "command": "svgPathHelper.transformToMatrixDeep",
          "when": "svgPathHelper.cursorOnTransform",
          "group": "svgPathHelperTransform@2"
        },
        {
          "command": "svgPathHelper.transformResolve",
          "when": "svgPathHelper.cursorOnTransform",
          "group": "svgPathHelperTransform@3"
        },
        {
          "command": "svgPathHelper.transformResolveDeep",
          "when": "svgPathHelper.cursorOnTransform",
          "group": "svgPathHelperTransform@4"
        }
      ]
    },
    "configuration": {
      "title": "SVG Path Helper",
      "properties": {
        "svgPathHelper.precision": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 12,
          "description": "Number of fractional digits to keep when converting coordinates."
        },
        "svgPathHelper.autoOpenPreview": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the preview beside an .svg file when it becomes active."
        },
        "svgPathHelper.lockPreviewGroup": {
          "type": "boolean",
          "default": true,
          "description": "Lock the preview's editor group so files opened from the Explorer go to your code column instead of opening on top of the preview. Disable to leave the group unlocked."
        },
        "svgPathHelper.openSvgFilesAsSource": {
          "type": "boolean",
          "default": true,
          "description": "While the preview is open, reopen SVG files chosen from the Explorer as source code instead of VS Code's built-in image preview, so the preview keeps following them. Only the built-in image preview is converted; third-party SVG editors are left alone."
        },
        "svgPathHelper.preview.background": {
          "type": "string",
          "enum": [
            "checker",
            "light",
            "dark"
          ],
          "default": "checker",
          "description": "Default preview background (also switchable from the preview toolbar)."
        },
        "svgPathHelper.preview.showGrid": {
          "type": "boolean",
          "default": true,
          "description": "Show the coordinate grid and rulers in the preview by default (toggle from the toolbar)."
        },
        "svgPathHelper.colors.command": {
          "type": "string",
          "default": "#4fc1ff",
          "description": "Color for path segment command letters (M, L, C, ...)."
        },
        "svgPathHelper.colors.endpoint": {
          "type": "string",
          "default": "#e8d44d",
          "description": "Color for the coordinates of a segment's end point."
        },
        "svgPathHelper.colors.control": {
          "type": "string",
          "default": "#6a9955",
          "description": "Color for the coordinates of control points."
        },
        "svgPathHelper.colors.segmentBg": {
          "type": "string",
          "default": "rgba(120,170,255,0.13)",
          "description": "Background highlight for the segment under the cursor."
        },
        "svgPathHelper.colors.pointBg": {
          "type": "string",
          "default": "rgba(255,220,0,0.30)",
          "description": "Background highlight for the point coordinates under the cursor."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p ./",
    "test": "node --import tsx --test test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "@vscode/test-web": "^0.0.81",
    "esbuild": "^0.20.2",
    "global-agent": "^4.1.3",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}
